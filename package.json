{
  "name": "@zhiaiwan/axios",
  "version": "1.0.0",
  "author": "Lixiaofei 61538187@qq.com",
  "description": "A modern, type-safe HTTP client built on top of axios with request cancellation, retry, token refresh, and interceptor pipeline.",
  "bugs": {
    "url": "https://github.com/qq61538187/zhiaiwan-axios/issues"
  },
  "homepage": "https://github.com/qq61538187/zhiaiwan-axios",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./global": {
      "types": "./dist/global.d.ts"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "README.en.md", "LICENSE"],
  "scripts": {
    "dev": "vite build --watch",
    "build": "vite build",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "biome check ./src ./tests",
    "fix": "biome check --write --verbose ./src ./tests",
    "prepublishOnly": "pnpm run build && pnpm run test:run",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "prepare": "husky",
    "examples": "node examples/server.js"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/qq61538187/zhiaiwan-axios.git"
  },
  "keywords": ["zhiaiwan", "axios", "http", "request", "fetch", "typescript"],
  "license": "MIT",
  "dependencies": {
    "axios": "^1.7.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.5",
    "@commitlint/cli": "^20.4.2",
    "@commitlint/config-conventional": "^20.4.2",
    "@rollup/plugin-terser": "^0.4.4",
    "@vitest/coverage-v8": "^3.2.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "typescript": "^5.7.0",
    "vite": "^6.1.0",
    "vite-plugin-dts": "^4.5.0",
    "vitest": "^3.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json}": ["biome check --write --no-errors-on-unmatched"]
  },
  "engines": {
    "node": ">=20"
  }
}
